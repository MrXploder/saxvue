{
  "name": "@mrxploder/saxvue",
  "version": "0.4.0",
  "description": "Framework components for Vue 3",
  "keywords": [
    "vue",
    "vue3",
    "ui",
    "components",
    "framework"
  ],
  "license": "MIT",
  "author": "MrXploder",
  "main": "dist/saxvue.js",
  "module": "dist/saxvue.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/saxvue.js",
      "require": "./dist/saxvue.js"
    },
    "./dist/*": "./dist/*"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "*.scss",
    "*.css"
  ],
  "files": [
    "dist",
    "types",
    "!types/test"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/MrXploder/saxvue"
  },
  "scripts": {
    "build": "node build/index.js",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "test": "jest --config jest.config.js",
    "test:coverage": "jest --config jest.config.js --coverage",
    "lint": "eslint --ext .ts,.tsx,.vue src test",
    "lint:fix": "eslint --ext .ts,.tsx,.vue src test --fix",
    "dev": "tsc -w src/index.ts --module es6",
    "test:types": "tsc -p ./types/test/tsconfig.json"
  },
  "dependencies": {
    "vue-router": "^4.1.6"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.6.2",
    "@babel/plugin-proposal-class-properties": "^7.5.5",
    "@babel/plugin-proposal-decorators": "^7.8.3",
    "@babel/plugin-proposal-numeric-separator": "^7.2.0",
    "@babel/plugin-proposal-object-rest-spread": "^7.6.2",
    "@babel/plugin-transform-runtime": "^7.6.2",
    "@babel/preset-env": "^7.6.3",
    "@babel/preset-typescript": "^7.6.0",
    "@babel/runtime": "^7.8.3",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "@vue/compiler-sfc": "^3.2.47",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.14",
    "babel-loader": "^8.3.0",
    "babel-plugin-transform-decorators-legacy": "^1.3.5",
    "chalk": "^4.1.2",
    "color": "^3.1.2",
    "css-loader": "^6.8.1",
    "css-minimizer-webpack-plugin": "^2.0.0",
    "cssnano": "^5.1.15",
    "csstype": "^3.1.3",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.23.0",
    "jest": "^29.6.1",
    "jest-environment-jsdom": "^30.2.0",
    "mini-css-extract-plugin": "^2.7.5",
    "postcss-loader": "^7.0.1",
    "prettier": "2.8.8",
    "sass": "^1.73.1",
    "sass-loader": "^13.2.2",
    "terser-webpack-plugin": "^5.3.6",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.4.2",
    "typescript": "^4.9.5",
    "vitepress": "^1.6.4",
    "vue-loader": "^16.8.3",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1",
    "webpack-merge": "^5.8.0",
    "webpackbar": "^5.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,vue}": "eslint --fix",
    "*.{ts,tsx,vue,json,md,scss,css}": "prettier --write"
  }
}
